{
  "name": "Home Server",
  "short_name": "HomeServer",
  "description": "Home server dashboard — files, processes, lights, backups, and more",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#0f1117",
  "theme_color": "#58a6ff",
  "orientation": "any",
  "icons": [
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Terminal",
      "short_name": "Term",
      "url": "/terminal",
      "description": "Open a live shell session"
    },
    {
      "name": "Files",
      "short_name": "Files",
      "url": "/files",
      "description": "Browse and manage server files"
    },
    {
      "name": "Docker",
      "short_name": "Docker",
      "url": "/docker",
      "description": "Manage Docker containers"
    },
    {
      "name": "Processes",
      "short_name": "Procs",
      "url": "/processes",
      "description": "Monitor running processes"
    }
  ],
  "share_target": {
    "action": "/api/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["*/*"]
        }
      ]
    }
  },
  "categories": ["utilities", "productivity"]
}
